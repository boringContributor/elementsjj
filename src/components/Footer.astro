---
import { Image } from 'astro:assets';
import logo from '../assets/ejj-logo.png';
import { SITE } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-card">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between md:gap-16">
      <div>
        <div class="flex items-center gap-2">
          <Image src={logo} alt="Elements Jiu Jitsu Regensburg Logo" width="80" height="80" class="h-10 w-10 object-contain" />
          <span class="font-display text-xl font-bold tracking-wider">
            Elements <span class="text-primary">Jiu Jitsu</span>
          </span>
        </div>
        <p class="mt-4 max-w-md text-sm text-muted-foreground">
          Brazilian Jiu-Jitsu, Muay Thai, MMA &amp; Grappling in Regensburg. Seit 2018.
        </p>
        <div class="mt-5 flex gap-3">
          <a
            href={SITE.social.instagram}
            target="_blank"
            rel="noreferrer"
            aria-label="Instagram"
            class="grid h-10 w-10 place-items-center rounded-md border border-border text-muted-foreground transition-smooth hover:border-primary hover:text-primary"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
            </svg>
          </a>
          <a
            href={SITE.social.facebook}
            target="_blank"
            rel="noreferrer"
            aria-label="Facebook"
            class="grid h-10 w-10 place-items-center rounded-md border border-border text-muted-foreground transition-smooth hover:border-primary hover:text-primary"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h2 class="font-display text-sm font-semibold tracking-widest text-foreground uppercase">Kontakt</h2>
        <address class="mt-4 space-y-3 text-sm text-muted-foreground not-italic">
          <p class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-primary" aria-hidden="true">
              <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <span>{SITE.address.street}<br />{SITE.address.zip} {SITE.address.city}</span>
          </p>
          <p>
            <a href={SITE.phoneHref} class="flex items-center gap-2 transition-smooth hover:text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-primary" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
              {SITE.phone}
            </a>
          </p>
          <p>
            <a href={`mailto:${SITE.email}`} class="flex items-center gap-2 transition-smooth hover:text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-primary" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
              {SITE.email}
            </a>
          </p>
        </address>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center gap-4 border-t border-border pt-6 text-xs text-muted-foreground sm:flex-row sm:justify-between">
      <p>© {year} Elements Jiu Jitsu Regensburg. Alle Rechte vorbehalten.</p>
      <div class="flex flex-col items-center gap-2 sm:flex-row sm:gap-4">
        <a href="/impressum" class="hover:text-primary">Impressum</a>
        <a href="/datenschutz" class="hover:text-primary">Datenschutzerklärung</a>
      </div>
    </div>
  </div>
</footer>

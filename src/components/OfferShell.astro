---
import BaseLayout from '../layouts/BaseLayout.astro';
import OfferSchedule from './OfferSchedule.astro';
import type { ImageMetadata } from 'astro';
import type { SportFilter } from '../data/schedule';

interface Props {
  title: string;
  description: string;
  kicker: string;
  heading: string;
  headingAccent?: string;
  subtitle: string;
  ogImage?: ImageMetadata;
  slug: string;
  /** [Label, Beschreibung] Paare für die Ausrüstungs-Liste */
  equipment: [string, string][];
  ctaLabel: string;
  scheduleFilter?: SportFilter;
  scheduleTitle?: string;
  scheduleDisciplineIncludes?: string[];
}

const {
  title,
  description,
  kicker,
  heading,
  headingAccent,
  subtitle,
  ogImage,
  slug,
  equipment,
  ctaLabel,
  scheduleFilter,
  scheduleTitle,
  scheduleDisciplineIncludes,
} = Astro.props;

const equipmentWithHygiene: [string, string][] = [
  ...equipment,
  [
    'Hausschuhe/Badeschlappen:',
    'Bitte bring Hausschuhe oder Badeschlappen mit, damit du abseits der Matte – insbesondere in der Umkleide – nicht barfuß laufen musst.',
  ],
];

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Kampfsportangebot', href: '/kampfsportangebote' },
  { name: heading, href: `/angebot/${slug}` },
];
---

<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumbs={breadcrumbs}>
  <article class="mx-auto max-w-4xl px-4 pt-6 pb-14 sm:px-6">
    <header class="mt-4">
      <p class="font-display text-sm font-semibold tracking-[0.2em] text-primary uppercase">{kicker}</p>
      <h1 class="font-display mt-3 text-3xl leading-tight font-bold uppercase sm:text-5xl">
        {heading}
        {headingAccent && (
          <>
            {' '}<span class="text-primary">{headingAccent}</span>
          </>
        )}
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted-foreground">{subtitle}</p>
    </header>

    <div class="mt-12 space-y-12">
      <slot />

      {scheduleFilter && <OfferSchedule filter={scheduleFilter} title={scheduleTitle} disciplineIncludes={scheduleDisciplineIncludes} />}

      <section>
        <h2 class="font-display text-2xl font-bold uppercase">Ausrüstung für dein erstes Training</h2>
        <ul class="mt-5 space-y-4">
          {equipmentWithHygiene.map(([label, text]) => (
            <li class="flex gap-3 rounded-lg border border-border bg-card p-4">
              <span class="mt-0.5 text-primary" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5" />
                </svg>
              </span>
              <p class="text-sm leading-relaxed text-muted-foreground">
                <strong class="text-foreground">{label}</strong> {text}
              </p>
            </li>
          ))}
        </ul>
      </section>

      <div class="text-center">
        <a
          href="/probetraining"
          class="gradient-neon shadow-neon inline-block rounded-md px-8 py-3 font-semibold text-primary-foreground transition-smooth hover:opacity-90"
        >
          {ctaLabel}
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

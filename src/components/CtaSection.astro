---
import { SITE } from '../data/site';
---

<section class="border-t border-border">
  <div class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6">
    <h2 class="font-display text-3xl font-bold uppercase sm:text-4xl">
      Mach noch heute dein <span class="text-primary">Schnuppertraining</span> aus!
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-muted-foreground">
      Komm vorbei, schnupper rein, roll mit uns. Dein erstes Training ist kostenlos.
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/probetraining"
        class="gradient-neon shadow-neon rounded-md px-8 py-3 font-semibold text-primary-foreground transition-smooth hover:opacity-90"
      >
        Probetraining buchen
      </a>
      <a href={SITE.phoneHref} class="text-sm text-muted-foreground transition-smooth hover:text-foreground">
        Oder ruf an: {SITE.phone}
      </a>
    </div>
  </div>
</section>

---
import SectionHeading from './SectionHeading.astro';
import { SITE } from '../data/site';

const reviewHighlights = [
  {
    title: 'Training & Technik',
    text: 'Strukturiertes Kampfsporttraining für Einsteiger, Fortgeschrittene und Wettkämpfer.',
  },
  {
    title: 'Coaches & Betreuung',
    text: 'Erfahrene Trainer, klare Anleitung und Unterstützung direkt auf der Matte.',
  },
  {
    title: 'Community & Atmosphäre',
    text: 'Familiäres Gym-Gefühl, respektvoller Umgang und Motivation in jeder Einheit.',
  },
];
---

<section class="border-t border-border bg-card/40">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <SectionHeading kicker="Google Bewertungen">
      Das sagen unsere Mitglieder
      <Fragment slot="sub">
        <p>Ein kompakter Überblick über das Feedback aus unserer Community.</p>
      </Fragment>
    </SectionHeading>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {reviewHighlights.map((review) => (
        <article class="flex h-full flex-col rounded-lg border border-border bg-card p-6 shadow-sm">
          <div class="flex gap-1 text-primary" aria-label="5 von 5 Sternen">
            {Array.from({ length: 5 }).map(() => (
              <span aria-hidden="true">★</span>
            ))}
          </div>
          <h3 class="font-display mt-5 text-lg font-bold uppercase text-foreground">
            {review.title}
          </h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-muted-foreground">
            {review.text}
          </p>
        </article>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a
        href={SITE.googleReviewsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-md border border-border px-6 py-3 font-semibold transition-smooth hover:border-primary hover:text-primary"
      >
        Alle Google Bewertungen ansehen
      </a>
    </div>
  </div>
</section>

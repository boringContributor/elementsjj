---
interface Props {
  kicker?: string;
  align?: 'left' | 'center';
  as?: 'h1' | 'h2';
}

const { kicker, align = 'center', as: Tag = 'h2' } = Astro.props;
---

<div class:list={['max-w-3xl', align === 'center' ? 'mx-auto text-center' : '']}>
  {kicker && (
    <p class="font-display text-sm font-semibold tracking-[0.2em] text-primary uppercase">{kicker}</p>
  )}
  <Tag class="font-display mt-2 text-3xl font-bold text-balance uppercase sm:text-4xl">
    <slot />
  </Tag>
  <div class="text-muted-foreground mt-4 [&>p]:leading-relaxed">
    <slot name="sub" />
  </div>
</div>

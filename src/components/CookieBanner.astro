---
const privacyHref = '/datenschutz';
---

<div
  id="cookie-banner"
  class="cookie-banner fixed right-4 bottom-20 left-4 z-50 hidden rounded-2xl border border-border bg-card/95 p-5 shadow-2xl backdrop-blur md:right-6 md:bottom-6 md:left-auto md:max-w-md"
  role="dialog"
  aria-live="polite"
  aria-label="Cookie-Hinweis"
>
  <div class="space-y-4">
    <div class="space-y-2">
      <p class="font-display text-lg font-semibold tracking-wide uppercase">Cookie-Hinweis</p>
      <p class="text-sm leading-relaxed text-muted-foreground">
        Wir verwenden aktuell nur technisch notwendige Funktionen für den Betrieb dieser Website.
        Mit „Verstanden“ speichern wir lediglich deine Entscheidung lokal im Browser, damit dieser
        Hinweis nicht erneut erscheint.
      </p>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <a href={privacyHref} class="text-sm font-medium text-primary underline-offset-4 hover:underline">
        Datenschutzerklärung
      </a>
      <button
        id="cookie-banner-accept"
        type="button"
        class="gradient-neon rounded-md px-5 py-2.5 text-sm font-semibold text-primary-foreground transition-smooth hover:brightness-110"
      >
        Verstanden
      </button>
    </div>
  </div>
</div>

<script>
  const storageKey = 'elementsjj-cookie-consent';
  const banner = document.getElementById('cookie-banner');
  const acceptButton = document.getElementById('cookie-banner-accept');

  const hasConsent = () => {
    try {
      return window.localStorage.getItem(storageKey) === 'accepted';
    } catch {
      return false;
    }
  };

  const saveConsent = () => {
    try {
      window.localStorage.setItem(storageKey, 'accepted');
    } catch {
      // Falls localStorage nicht verfügbar ist, wird der Hinweis trotzdem für diese Sitzung ausgeblendet.
    }
  };

  if (banner && !hasConsent()) {
    banner.classList.remove('hidden');
  }

  acceptButton?.addEventListener('click', () => {
    saveConsent();
    banner?.classList.add('hidden');
  });
</script>

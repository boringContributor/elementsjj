---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import OfferCard from '../components/OfferCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { SITE, LOCATIONS } from '../data/site';
import { OFFERS } from '../data/offers';
import { TRAINERS, HEADCOACH } from '../data/trainers';
import { HOME_SCHEDULE_SUMMARY } from '../data/schedule';
import heroImage from '../assets/hero-bjj.jpg';
import coachMax from '../assets/coach-max.jpg';

const accentText = { blue: 'text-course-blue', red: 'text-primary', gold: 'text-course-blue' } as const;

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: Astro.site?.href,
  inLanguage: 'de-DE',
};
---

<BaseLayout
  title="Elements Jiu Jitsu Regensburg — BJJ, MMA & Thaiboxen"
  description={SITE.description}
  jsonLd={[websiteLd]}
  hideStickyCta
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={heroImage}
        alt="BJJ-Training bei Elements Jiu Jitsu Regensburg"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="h-full w-full object-cover object-[60%_35%]"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-background via-background/75 to-background/35 sm:bg-gradient-to-r sm:from-background sm:via-background/80 sm:to-background/30"></div>
    </div>
    <div class="relative mx-auto flex min-h-[70dvh] max-w-7xl flex-col justify-end px-4 pt-40 pb-16 sm:justify-center sm:py-28 lg:min-h-[75dvh] lg:py-40">
      <p class="font-display text-sm font-semibold tracking-[0.25em] text-course-blue uppercase">
        Regensburg · seit 2018
      </p>
      <h1 class="font-display mt-4 max-w-3xl text-4xl leading-tight font-bold uppercase sm:text-6xl">
        <span class="sr-only">Elements Jiu Jitsu — Kampfsport in Regensburg: BJJ, MMA &amp; Thaiboxen — </span>
        Kampfsport. <span class="text-primary">Disziplin.</span> Fortschritt.
      </h1>
      <p class="mt-6 max-w-xl text-lg text-muted-foreground">
        BJJ, MMA, Thaiboxen &amp; Grappling in Regensburg &amp; Kelheim. Echte Technik. Echte Community.
        Vom Anfänger bis zum Wettkämpfer.
      </p>
      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        <a
          href="/probetraining"
          class="gradient-neon shadow-neon rounded-md px-8 py-3 text-center font-semibold text-primary-foreground transition-smooth hover:opacity-90"
        >
          Jetzt Schnuppertraining buchen
        </a>
        <a
          href="/stundenplan"
          class="rounded-md border border-border px-8 py-3 text-center font-semibold transition-smooth hover:border-primary hover:text-primary"
        >
          Stundenplan ansehen
        </a>
      </div>
    </div>
  </section>

  <!-- Kampfsportangebot -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <SectionHeading kicker="Was wir trainieren">
      Unser Kampfsport-Angebot
      <Fragment slot="sub">
        <p>Acht Programme unter einem Dach — für jedes Level, jedes Alter.</p>
      </Fragment>
    </SectionHeading>
    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {OFFERS.map((offer) => (
        <OfferCard offer={offer} />
      ))}
    </div>
  </section>

  <!-- Team -->
  <section class="border-t border-border bg-card/40">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
      <SectionHeading kicker="Coaches & Athleten">
        Unser Trainer-Team
        <Fragment slot="sub">
          <p>
            23 Coaches, eine Mission: dich besser machen. Vom Schwarzgurt-Headcoach bis zum jungen
            Athleten — bei EJJ trainieren echte Mattenleute.
          </p>
        </Fragment>
      </SectionHeading>

      <!-- Coach Highlight -->
      <div class="mt-10 grid items-center gap-8 rounded-lg border border-border bg-card p-6 sm:p-10 lg:grid-cols-[280px_1fr]">
        <Image
          src={coachMax}
          alt="Maximilian Alkofer — Inhaber & Headcoach von Elements Jiu Jitsu Regensburg"
          widths={[280, 560]}
          sizes="(max-width: 1024px) 280px, 280px"
          class="mx-auto aspect-square w-64 rounded-lg object-cover object-top lg:w-full"
          loading="lazy"
        />
        <div>
          <p class="font-display text-xs font-semibold tracking-[0.25em] text-course-blue uppercase">
            Coach Highlight · Headcoach
          </p>
          <h3 class="font-display mt-2 text-2xl font-bold uppercase">{HEADCOACH.shortName}</h3>
          <p class="mt-3 leading-relaxed text-muted-foreground">{HEADCOACH.bio}</p>
          <ul class="mt-5 flex flex-wrap gap-2">
            {HEADCOACH.credentials.map((credential) => (
              <li class="rounded-full border border-border px-3 py-1 text-xs font-medium text-muted-foreground">
                {credential}
              </li>
            ))}
          </ul>
          <p class="mt-5 text-sm text-muted-foreground">
            <a
              href={HEADCOACH.brand.url}
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold text-course-blue transition-smooth hover:opacity-80"
            >
              {HEADCOACH.brand.label}
            </a>
            · {HEADCOACH.brand.code}
          </p>
        </div>
      </div>

      <ul class="mt-12 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {TRAINERS.filter((trainer) => trainer.name !== HEADCOACH.name)
          .slice(0, 12)
          .map((trainer) => (
          <li class="group relative overflow-hidden rounded-lg border border-border">
            <Image
              src={trainer.image}
              alt={`${trainer.name} — Trainer bei Elements Jiu Jitsu`}
              widths={[240, 480]}
              sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
              class="aspect-[4/5] w-full object-cover object-top transition-smooth group-hover:scale-105"
              loading="lazy"
            />
            <span class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 to-transparent px-3 pt-10 pb-2.5 text-sm leading-tight font-semibold text-white">
              {trainer.name}
            </span>
          </li>
        ))}
      </ul>

      <div class="mt-6 text-center">
        <a href="/team" class="text-sm font-semibold text-primary transition-smooth hover:opacity-80">
          Zum Team →
        </a>
      </div>

    </div>
  </section>

  <!-- Stundenplan-Überblick -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <SectionHeading kicker="Stundenplan auf einen Blick">
      Wann du trainieren kannst
    </SectionHeading>
    <div class="mx-auto mt-12 grid max-w-6xl gap-6 md:grid-cols-3">
      {HOME_SCHEDULE_SUMMARY.map((gym) => (
        <div class="rounded-lg border border-border bg-card p-6">
          <h3 class:list={['font-display text-lg font-bold tracking-wide uppercase', accentText[gym.accent]]}>
            {gym.location}
          </h3>
          <dl class="mt-4 space-y-2 text-sm">
            {gym.days.map(([day, classes]) => (
              <div class="flex gap-3">
                <dt class="w-8 shrink-0 font-mono font-semibold text-muted-foreground">{day}</dt>
                <dd class="text-foreground/90">{classes}</dd>
              </div>
            ))}
          </dl>
        </div>
      ))}
    </div>
    <div class="mt-8 text-center">
      <a
        href="/stundenplan"
        class="inline-block rounded-md border border-border px-6 py-3 font-semibold transition-smooth hover:border-primary hover:text-primary"
      >
        Vollständiger Stundenplan
      </a>
    </div>
  </section>

  <!-- Standorte & Anfänger-Info -->
  <section class="border-t border-border bg-card/40">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
      <SectionHeading kicker="Wo wir trainieren">
        Standorte &amp; Anfänger-Info
      </SectionHeading>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {LOCATIONS.map((loc) => (
          <div class="rounded-lg border border-border bg-card p-6">
            <h3 class:list={['font-display text-lg font-bold uppercase', accentText[loc.accent]]}>{loc.name}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{loc.address}</p>
          </div>
        ))}
      </div>
      <div class="mt-6 grid gap-6 md:grid-cols-2">
        <div class="rounded-lg border border-border bg-card p-6">
          <h3 class="font-display text-base font-bold uppercase">Probetraining für Minderjährige</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Bei Minderjährigen muss ein Erziehungsberechtigter vor Ort einen Haftungsausschluss
            unterschreiben. Bringt bitte einen Personalausweis mit.
          </p>
        </div>
        <div class="rounded-lg border border-border bg-card p-6">
          <h3 class="font-display text-base font-bold uppercase">Du bist Anfänger?</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Kein Problem! Wir integrieren dich direkt ins normale Training mit erfahrenem
            Trainingspartner. Es gibt kein zu alt und kein zu unsportlich.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>

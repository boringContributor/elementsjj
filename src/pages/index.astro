---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import CtaSection from '../components/CtaSection.astro';
import { SITE, LOCATIONS } from '../data/site';
import { OFFERS } from '../data/offers';
import { TRAINERS, HEADCOACH } from '../data/trainers';
import { HOME_SCHEDULE_SUMMARY } from '../data/schedule';

const accentText = { blue: 'text-course-blue', red: 'text-primary', gold: 'text-gold' } as const;
const accentBg = { blue: 'from-course-blue/24', red: 'from-primary/24', gold: 'from-gold/24' } as const;
const shortOfferLabels = ['BJJ', 'Frauen', 'Kids', 'MMA', 'Kickboxen', 'NoGi', 'Thaiboxen', 'Start'];

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: Astro.site?.href,
  inLanguage: 'de-DE',
};
---

<BaseLayout
  title="Elements Jiu Jitsu Regensburg — BJJ, MMA & Thaiboxen"
  description={SITE.description}
  jsonLd={[websiteLd]}
  hideStickyCta
>
  <!--
    Eigenständige Homepage-Optik ohne externe Vorlagen- oder Stockmotiv-Anmutung.
    Rückgängig machen: diesen Commit revertieren oder die vorherige index.astro aus Git wiederherstellen.
  -->
  <section class="relative isolate overflow-hidden border-b border-border bg-[radial-gradient(circle_at_15%_20%,rgba(58,172,255,0.22),transparent_30%),radial-gradient(circle_at_85%_15%,rgba(245,32,39,0.16),transparent_28%),linear-gradient(135deg,#040a11_0%,#0b1420_55%,#07101a_100%)]">
    <div class="pointer-events-none absolute inset-0 opacity-35 [background-image:linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] [background-size:44px_44px]"></div>
    <div class="relative mx-auto grid min-h-[76dvh] max-w-7xl items-center gap-12 px-4 py-24 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:py-32">
      <div>
        <p class="font-display text-sm font-semibold tracking-[0.32em] text-course-blue uppercase">
          Regensburg · Kelheim · seit 2018
        </p>
        <h1 class="font-display mt-5 max-w-4xl text-5xl leading-[0.95] font-bold tracking-tight uppercase sm:text-7xl lg:text-8xl">
          Klare Technik.<br />Starkes Team.<br /><span class="text-primary">Dein Mattenstart.</span>
        </h1>
        <p class="mt-7 max-w-2xl text-lg leading-relaxed text-muted-foreground sm:text-xl">
          Brazilian Jiu Jitsu, NoGi Grappling, MMA, Thaiboxen und Kindertraining — strukturiert,
          persönlich und offen für Einsteiger, Fortgeschrittene und Wettkämpfer.
        </p>
        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <a href="/probetraining" class="rounded-full bg-primary px-8 py-3 text-center font-semibold text-primary-foreground transition-smooth hover:bg-primary-dark">
            Schnuppertraining buchen
          </a>
          <a href="/stundenplan" class="rounded-full border border-border bg-background/35 px-8 py-3 text-center font-semibold backdrop-blur transition-smooth hover:border-course-blue hover:text-course-blue">
            Trainingszeiten ansehen
          </a>
        </div>
      </div>
      <div class="relative mx-auto w-full max-w-lg lg:max-w-none" aria-hidden="true">
        <div class="aspect-square rounded-[2.5rem] border border-white/10 bg-card/60 p-6 shadow-2xl backdrop-blur">
          <div class="grid h-full grid-cols-2 gap-4">
            {['Technik', 'Respekt', 'Fitness', 'Community'].map((value, index) => (
              <div class:list={['flex items-end rounded-[1.75rem] border border-white/10 bg-gradient-to-br to-transparent p-5', index % 2 === 0 ? 'from-course-blue/20' : 'from-primary/20']}>
                <span class="font-display text-2xl font-bold uppercase">{value}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="absolute -right-4 -bottom-4 rounded-3xl border border-gold/30 bg-gold/10 px-5 py-4 text-sm font-semibold text-gold backdrop-blur">
          3 Standorte · 8 Programme
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <SectionHeading kicker="Was wir trainieren">
      Unser Kampfsport-Angebot
      <Fragment slot="sub"><p>Acht Programme unter einem Dach — ohne austauschbare Bildsprache, direkt auf deine Ziele fokussiert.</p></Fragment>
    </SectionHeading>
    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {OFFERS.map((offer, index) => (
        <a href={offer.href} class="group rounded-3xl border border-border bg-card p-6 transition-smooth hover:-translate-y-1 hover:border-primary/60">
          <div class="flex h-24 items-start justify-between">
            <span class:list={['rounded-2xl bg-gradient-to-br to-transparent px-4 py-3 font-display text-2xl font-bold', accentBg[index % 3 === 0 ? 'blue' : index % 3 === 1 ? 'red' : 'gold']]}>{shortOfferLabels[index]}</span>
            <span class="text-2xl text-primary transition-smooth group-hover:translate-x-1">→</span>
          </div>
          <h3 class="font-display mt-6 text-xl font-semibold tracking-wide uppercase">{offer.name}</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{offer.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <GoogleReviews />

  <section class="border-t border-border bg-card/40">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
      <SectionHeading kicker="Coaches & Athleten">
        Unser Trainer-Team
        <Fragment slot="sub"><p>Kompetenz sichtbar gemacht über Erfahrung, Rollen und Schwerpunkte statt über großflächige Personenmotive.</p></Fragment>
      </SectionHeading>
      <div class="mt-10 rounded-3xl border border-border bg-background/65 p-8 sm:p-10">
        <p class="font-display text-xs font-semibold tracking-[0.25em] text-course-blue uppercase">Headcoach</p>
        <h3 class="font-display mt-2 text-3xl font-bold uppercase">{HEADCOACH.shortName}</h3>
        <p class="mt-4 max-w-3xl leading-relaxed text-muted-foreground">{HEADCOACH.bio}</p>
        <ul class="mt-6 flex flex-wrap gap-2">
          {HEADCOACH.credentials.map((credential) => <li class="rounded-full border border-border px-3 py-1 text-xs font-medium text-muted-foreground">{credential}</li>)}
        </ul>
      </div>
      <ul class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
        {TRAINERS.filter((trainer) => trainer.name !== HEADCOACH.name).slice(0, 12).map((trainer) => (
          <li class="rounded-2xl border border-border bg-card p-4">
            <span class="font-display text-lg font-bold text-foreground">{trainer.name.split(' ').map((part) => part[0]).join('').slice(0, 2)}</span>
            <p class="mt-2 text-sm font-semibold">{trainer.name}</p>
          </li>
        ))}
      </ul>
      <div class="mt-8 text-center"><a href="/team" class="text-sm font-semibold text-primary transition-smooth hover:opacity-80">Zum Team →</a></div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <SectionHeading kicker="Stundenplan auf einen Blick">Wann du trainieren kannst</SectionHeading>
    <div class="mx-auto mt-12 grid max-w-6xl gap-6 md:grid-cols-3">
      {HOME_SCHEDULE_SUMMARY.map((gym) => (
        <div class="rounded-3xl border border-border bg-card p-6">
          <h3 class:list={['font-display text-lg font-bold tracking-wide uppercase', accentText[gym.accent]]}>{gym.location}</h3>
          <dl class="mt-4 space-y-2 text-sm">
            {gym.days.map(([day, classes]) => <div class="flex gap-3"><dt class="w-8 shrink-0 font-mono font-semibold text-muted-foreground">{day}</dt><dd class="text-foreground/90">{classes}</dd></div>)}
          </dl>
        </div>
      ))}
    </div>
    <div class="mt-8 text-center"><a href="/stundenplan" class="inline-block rounded-full border border-border px-6 py-3 font-semibold transition-smooth hover:border-primary hover:text-primary">Vollständiger Stundenplan</a></div>
  </section>

  <section class="border-t border-border bg-card/40">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
      <SectionHeading kicker="Wo wir trainieren">Standorte &amp; Anfänger-Info</SectionHeading>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {LOCATIONS.map((loc) => <div class="rounded-3xl border border-border bg-card p-6"><h3 class:list={['font-display text-lg font-bold uppercase', accentText[loc.accent]]}>{loc.name}</h3><p class="mt-2 text-sm text-muted-foreground">{loc.address}</p></div>)}
      </div>
      <div class="mt-6 grid gap-6 md:grid-cols-2">
        <div class="rounded-3xl border border-border bg-card p-6"><h3 class="font-display text-base font-bold uppercase">Probetraining für Minderjährige</h3><p class="mt-2 text-sm leading-relaxed text-muted-foreground">Bei Minderjährigen muss ein Erziehungsberechtigter vor Ort einen Haftungsausschluss unterschreiben. Bringt bitte einen Personalausweis mit.</p></div>
        <div class="rounded-3xl border border-border bg-card p-6"><h3 class="font-display text-base font-bold uppercase">Du bist Anfänger?</h3><p class="mt-2 text-sm leading-relaxed text-muted-foreground">Kein Problem! Wir integrieren dich direkt ins normale Training mit erfahrenem Trainingspartner. Es gibt kein zu alt und kein zu unsportlich.</p></div>
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>

---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import OfferCard from '../components/OfferCard.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import CtaSection from '../components/CtaSection.astro';
import { SITE, LOCATIONS } from '../data/site';
import { OFFERS } from '../data/offers';
import { TRAINERS, HEADCOACH } from '../data/trainers';
import { HOME_SCHEDULE_SUMMARY } from '../data/schedule';
import heroImage from '../assets/DSC03973.jpg';
import coachMax from '../assets/coach-max.jpg';

const accentText = { blue: 'text-course-blue', red: 'text-primary', gold: 'text-gold' } as const;
const quickLinks = [
  { label: 'Angebote', href: '#angebote', value: `${OFFERS.length} Programme` },
  { label: 'Training', href: '#training', value: '3 Standorte' },
  { label: 'Team', href: '#team', value: `${TRAINERS.length} Coaches` },
];

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: Astro.site?.href,
  inLanguage: 'de-DE',
};
---

<BaseLayout
  title="Elements Jiu Jitsu Regensburg — BJJ, MMA & Thaiboxen"
  description={SITE.description}
  jsonLd={[websiteLd]}
  hideStickyCta
>
  <!--
    Eigenständige Startseiten-Struktur: Fotos und Inhalte bleiben erhalten, aber die Komposition
    ist bewusst als eigener Homepage-Ablauf angelegt. Rückgängig: diesen Commit revertieren.
  -->
  <section class="relative overflow-hidden border-b border-border bg-background">
    <div class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-primary/10 to-transparent"></div>
    <div class="relative mx-auto grid min-h-[72dvh] max-w-7xl items-center gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:py-24">
      <div class="order-2 lg:order-1">
        <p class="font-display text-sm font-semibold tracking-[0.25em] text-course-blue uppercase">
          REGENSBURG - KELHEIM - SEIT 2018
        </p>
        <h1 class="font-display mt-4 max-w-3xl text-4xl leading-tight font-bold uppercase sm:text-6xl">
          <span class="sr-only">Elements Jiu Jitsu — Kampfsport in Regensburg: BJJ, MMA &amp; Thaiboxen — </span>
          Kampfsport mit Struktur. <span class="text-primary">Training mit Team.</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg text-muted-foreground">
          BJJ, MMA, Thaiboxen &amp; Grappling in Regensburg — Brazilian Jiu Jitsu &amp; NoGi Grappling auch in Kelheim.
          Echte Technik. Echte Community. Vom Anfänger bis zum Wettkämpfer.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="/probetraining" class="gradient-neon shadow-neon rounded-md px-8 py-3 text-center font-semibold text-primary-foreground transition-smooth hover:opacity-90">
            Jetzt Schnuppertraining buchen
          </a>
          <a href="/stundenplan" class="rounded-md border border-border px-8 py-3 text-center font-semibold transition-smooth hover:border-primary hover:text-primary">
            Stundenplan ansehen
          </a>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <div class="relative overflow-hidden rounded-[2rem] border border-border bg-card p-3 shadow-2xl">
          <Image
            src={heroImage}
            alt="BJJ-Training bei Elements Jiu Jitsu Regensburg"
            widths={[640, 960, 1280]}
            sizes="(max-width: 1024px) 100vw, 54vw"
            format="webp"
            quality={72}
            class="aspect-[4/3] w-full rounded-[1.4rem] object-cover object-[60%_35%]"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <div class="absolute right-6 bottom-6 rounded-xl border border-white/15 bg-background/80 px-4 py-3 backdrop-blur">
            <p class="font-display text-xs tracking-[0.22em] text-course-blue uppercase">Heute starten</p>
            <p class="mt-1 text-sm font-semibold">Probetraining kostenlos</p>
          </div>
        </div>
      </div>
    </div>
    <nav class="relative mx-auto grid max-w-7xl gap-3 px-4 pb-12 sm:grid-cols-3 sm:px-6" aria-label="Startseiten-Überblick">
      {quickLinks.map((item) => (
        <a href={item.href} class="rounded-lg border border-border bg-card/80 p-5 transition-smooth hover:-translate-y-1 hover:border-primary/60">
          <span class="text-sm text-muted-foreground">{item.label}</span>
          <strong class="mt-1 block font-display text-xl uppercase">{item.value}</strong>
        </a>
      ))}
    </nav>
  </section>

  <section id="angebote" class="mx-auto grid max-w-7xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[320px_1fr]">
    <div>
      <SectionHeading kicker="Was wir trainieren">
        Unser Kampfsport-Angebot
        <Fragment slot="sub">
          <p>Acht Programme unter einem Dach — nach Alter, Ziel und Erfahrungslevel schnell auffindbar.</p>
        </Fragment>
      </SectionHeading>
      <a href="/kampfsportangebote" class="mt-6 inline-block rounded-md border border-border px-5 py-3 text-sm font-semibold transition-smooth hover:border-primary hover:text-primary">
        Alle Angebote vergleichen
      </a>
    </div>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
      {OFFERS.map((offer) => (
        <OfferCard offer={offer} />
      ))}
    </div>
  </section>

  <section id="training" class="border-y border-border bg-card/40">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[1fr_1.2fr]">
      <div>
        <SectionHeading kicker="Training planen">
          Standorte &amp; Zeiten
          <Fragment slot="sub">
            <p>Die wichtigsten Trainingsfenster und Adressen auf einer kompakten Einstiegsfläche.</p>
          </Fragment>
        </SectionHeading>
        <div class="mt-8 grid gap-4">
          {LOCATIONS.map((loc) => (
            <div class="rounded-lg border border-border bg-card p-5">
              <h3 class:list={['font-display text-lg font-bold uppercase', accentText[loc.accent]]}>{loc.name}</h3>
              <p class="mt-2 text-sm text-muted-foreground">{loc.address}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="grid content-start gap-6 md:grid-cols-3 lg:pt-16">
        {HOME_SCHEDULE_SUMMARY.map((gym) => (
          <div class="rounded-lg border border-border bg-background p-6">
            <h3 class:list={['font-display text-lg font-bold tracking-wide uppercase', accentText[gym.accent]]}>{gym.location}</h3>
            <dl class="mt-4 space-y-2 text-sm">
              {gym.days.map(([day, classes]) => (
                <div class="flex gap-3">
                  <dt class="w-8 shrink-0 font-mono font-semibold text-muted-foreground">{day}</dt>
                  <dd class="text-foreground/90">{classes}</dd>
                </div>
              ))}
            </dl>
          </div>
        ))}
        <div class="md:col-span-3">
          <a href="/stundenplan" class="inline-block rounded-md border border-border px-6 py-3 font-semibold transition-smooth hover:border-primary hover:text-primary">
            Vollständiger Stundenplan
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="team" class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <SectionHeading kicker="Coaches & Athleten">
      Unser Trainer-Team
      <Fragment slot="sub">
        <p>Vom Schwarzgurt-Headcoach bis zum jungen Athleten — bei EJJ trainieren echte Matpeople.</p>
      </Fragment>
    </SectionHeading>
    <div class="mt-10 grid gap-8 lg:grid-cols-[360px_1fr]">
      <div class="rounded-lg border border-border bg-card p-6">
        <Image
          src={coachMax}
          alt="Maximilian Alkofer — Inhaber & Headcoach von Elements Jiu Jitsu Regensburg"
          widths={[360, 720]}
          sizes="(max-width: 1024px) 100vw, 360px"
          class="aspect-[4/5] w-full rounded-lg object-cover object-top"
          loading="lazy"
        />
        <p class="font-display mt-6 text-xs font-semibold tracking-[0.25em] text-course-blue uppercase">Headcoach</p>
        <h3 class="font-display mt-2 text-2xl font-bold uppercase">{HEADCOACH.shortName}</h3>
        <p class="mt-3 leading-relaxed text-muted-foreground">{HEADCOACH.bio}</p>
        <ul class="mt-5 flex flex-wrap gap-2">
          {HEADCOACH.credentials.map((credential) => (
            <li class="rounded-full border border-border px-3 py-1 text-xs font-medium text-muted-foreground">{credential}</li>
          ))}
        </ul>
      </div>
      <div>
        <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3">
          {TRAINERS.filter((trainer) => trainer.name !== HEADCOACH.name).slice(0, 12).map((trainer) => (
            <li class="group relative overflow-hidden rounded-lg border border-border">
              <Image
                src={trainer.image}
                alt={`${trainer.name} — Trainer bei Elements Jiu Jitsu`}
                widths={[240, 480]}
                sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 18vw"
                class="aspect-[4/5] w-full object-cover object-top transition-smooth group-hover:scale-105"
                loading="lazy"
              />
              <span class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 to-transparent px-3 pt-10 pb-2.5 text-sm leading-tight font-semibold text-white">{trainer.name}</span>
            </li>
          ))}
        </ul>
        <div class="mt-6 text-right">
          <a href="/team" class="text-sm font-semibold text-primary transition-smooth hover:opacity-80">Zum Team →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-border bg-card/40">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 py-12 sm:px-6 md:grid-cols-2">
      <div class="rounded-lg border border-border bg-card p-6">
        <h3 class="font-display text-base font-bold uppercase">Probetraining für Minderjährige</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Bei Minderjährigen muss ein Erziehungsberechtigter vor Ort einen Haftungsausschluss
          unterschreiben. Bringt bitte einen Personalausweis mit.
        </p>
      </div>
      <div class="rounded-lg border border-border bg-card p-6">
        <h3 class="font-display text-base font-bold uppercase">Du bist Anfänger?</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Kein Problem! Wir integrieren dich direkt ins normale Training mit erfahrenem
          Trainingspartner. Es gibt kein zu alt und kein zu unsportlich.
        </p>
      </div>
    </div>
  </section>

  <GoogleReviews />

  <CtaSection />
</BaseLayout>

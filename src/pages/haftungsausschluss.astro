---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Haftungsausschluss — Elements Jiu Jitsu Regensburg"
  description="Haftungsausschluss und Teilnahmeerklärung für Elements Jiu Jitsu Regensburg."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Haftungsausschluss', href: '/haftungsausschluss' },
  ]}
  noindex
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-display text-sm font-semibold tracking-[0.2em] text-primary uppercase">
        Teilnahmeerklärung
      </p>
      <h1 class="font-display mt-2 text-4xl font-bold uppercase sm:text-5xl">
        Haftungs<span class="text-primary">ausschluss</span>
      </h1>
      <p class="mt-4 text-lg text-muted-foreground">
        Bitte fülle das folgende Formular vollständig aus, bevor du am Training teilnimmst.
      </p>
    </div>

    <div class="mt-10 overflow-hidden rounded-2xl border border-border bg-card p-4 shadow-xl sm:p-6">
      <div
        id="form123-consent-placeholder"
        class="flex min-h-[420px] flex-col items-center justify-center gap-4 px-6 py-12 text-center"
        data-form123-src="https://form.123formbuilder.com/embed/6388127.js"
      >
        <div class="max-w-xl space-y-3">
          <p class="font-display text-xl font-semibold tracking-wide uppercase">Externes Haftungsformular laden</p>
          <p class="text-sm leading-relaxed text-muted-foreground">
            Für den Haftungsausschluss nutzen wir ein Formular von 123FormBuilder. Beim Laden können
            personenbezogene Daten wie deine IP-Adresse an 123FormBuilder übertragen und dort
            Cookies oder ähnliche Technologien eingesetzt werden.
          </p>
        </div>
        <button
          id="form123-consent-button"
          type="button"
          class="gradient-neon rounded-md px-5 py-2.5 text-sm font-semibold text-primary-foreground transition-smooth hover:brightness-110"
        >
          123FormBuilder-Formular laden
        </button>
        <a href="/datenschutz" class="text-sm font-medium text-primary underline-offset-4 hover:underline">
          Hinweise zum Datenschutz
        </a>
      </div>
    </div>
  </section>
</BaseLayout>


<script>
  const storageKey = 'elementsjj-cookie-consent';
  const placeholder = document.getElementById('form123-consent-placeholder');
  const form123Button = document.getElementById('form123-consent-button');

  const readConsent = () => {
    try {
      const rawConsent = window.localStorage.getItem(storageKey);
      if (!rawConsent) return null;
      if (rawConsent === 'accepted') return { essential: true, external: false };
      return JSON.parse(rawConsent);
    } catch {
      return null;
    }
  };

  const saveExternalConsent = () => {
    const consent = { essential: true, external: true, updatedAt: new Date().toISOString() };
    try {
      window.localStorage.setItem(storageKey, JSON.stringify(consent));
    } catch {
      // Wenn localStorage nicht verfügbar ist, laden wir das Formular nur für den aktuellen Seitenaufruf.
    }
    window.dispatchEvent(new CustomEvent('elementsjj:consent-updated', { detail: consent }));
  };

  const load123Form = () => {
    if (!placeholder || placeholder.dataset.loaded === 'true') return;
    const source = placeholder.dataset.form123Src;
    if (!source) return;

    const script = document.createElement('script');
    script.type = 'text/javascript';
    script.defer = true;
    script.src = source;
    script.dataset.role = 'form';
    script.dataset.defaultWidth = '800px';
    script.dataset.customVars = 'hasEmbedFormStyle=1';

    placeholder.dataset.loaded = 'true';
    placeholder.replaceWith(script);
  };

  if (readConsent()?.external) {
    load123Form();
  }

  form123Button?.addEventListener('click', () => {
    saveExternalConsent();
    load123Form();
  });

  window.addEventListener('elementsjj:consent-updated', (event) => {
    if (event instanceof CustomEvent && event.detail?.external) {
      load123Form();
    }
  });
</script>

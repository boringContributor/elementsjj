---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Seite nicht gefunden — Elements Jiu Jitsu Regensburg"
  description="Diese Seite existiert nicht oder wurde verschoben."
  noindex
>
  <section class="mx-auto max-w-3xl px-4 py-32 text-center sm:px-6">
    <p class="font-display text-6xl font-bold text-primary">404</p>
    <h1 class="font-display mt-4 text-3xl font-bold uppercase">Seite nicht gefunden</h1>
    <p class="mt-4 text-muted-foreground">
      Die gesuchte Seite existiert nicht oder wurde verschoben.
    </p>
    <a
      href="/"
      class="gradient-neon mt-8 inline-block rounded-md px-8 py-3 font-semibold text-primary-foreground transition-smooth hover:opacity-90"
    >
      Zur Startseite
    </a>
  </section>
</BaseLayout>

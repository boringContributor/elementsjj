---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, LOCATIONS } from '../data/site';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Probetraining', href: '/probetraining' },
];

const accentText = { blue: 'text-course-blue', red: 'text-primary', gold: 'text-gold' } as const;

const checklist = [
  'Sportkleidung (kurze Hose, T-Shirt)',
  'Wasserflasche & Handtuch',
  'Gute Laune & Offenheit',
  'Gi (BJJ): leihen wir dir gerne',
];
---

<BaseLayout
  title="Kostenloses Probetraining — Elements Jiu Jitsu Regensburg"
  description="Buche dein kostenloses Probetraining bei EJJ Regensburg. BJJ, MMA, Thaiboxen — Anfänger willkommen."
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-display text-sm font-semibold tracking-[0.2em] text-primary uppercase">
        Gratis &amp; unverbindlich
      </p>
      <h1 class="font-display mt-2 text-3xl font-bold uppercase sm:text-4xl">
        Dein <span class="text-primary">Probetraining</span>
      </h1>
      <p class="mt-4 text-muted-foreground">
        Buch dein kostenloses Probetraining direkt online — wir freuen uns auf dich!
      </p>
    </div>

    <div class="mt-12 grid items-start gap-8 lg:grid-cols-[minmax(0,1fr)_340px]">
      <div class="overflow-hidden rounded-lg border border-border bg-card">
        <iframe
          src={SITE.matoolFormUrl}
          title="Probetraining-Anmeldung (Buchungsformular von MATOOL)"
          class="block h-[max(860px,calc(100dvh-11rem))] w-full"
          loading="lazy"
        ></iframe>
        <p class="border-t border-border px-4 py-2 text-right text-xs text-muted-foreground">
          made by
          <a href="https://www.matool.de" target="_blank" rel="noopener noreferrer" class="font-semibold hover:text-primary">MATOOL</a>
        </p>
      </div>

      <aside class="space-y-4">
        <div class="rounded-lg border border-border bg-card p-6">
          <h2 class="font-display text-base font-bold tracking-wider uppercase">Standorte</h2>
          <ul class="mt-4 space-y-4">
            {LOCATIONS.map((loc) => (
              <li>
                <p class:list={['font-display text-sm font-semibold uppercase', accentText[loc.accent]]}>{loc.name}</p>
                <p class="text-sm text-muted-foreground">{loc.address}</p>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-lg border border-border bg-card p-6">
          <h2 class="font-display text-base font-bold tracking-wider uppercase">Direkt anrufen</h2>
          <a href={SITE.phoneHref} class="mt-2 inline-block text-lg font-semibold text-primary transition-smooth hover:opacity-80">
            {SITE.phone}
          </a>
        </div>

        <div class="rounded-lg border border-border bg-card p-6">
          <h2 class="font-display text-base font-bold tracking-wider uppercase">Hinweis für Minderjährige</h2>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Beim Probetraining muss ein Erziehungsberechtigter vor Ort einen Haftungsausschluss
            unterschreiben.
          </p>
        </div>

        <div class="rounded-lg border border-border bg-card p-6">
          <h2 class="font-display text-base font-bold tracking-wider uppercase">Was du mitbringen solltest</h2>
          <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
            {checklist.map((item) => (
              <li class="flex gap-2">
                <span class="text-primary" aria-hidden="true">•</span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-lg border border-border bg-card p-6">
          <h2 class="font-display text-base font-bold tracking-wider uppercase">Disziplinen &amp; Zeiten finden</h2>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Alle Termine und Standorte für BJJ, MMA, Thaiboxen, Grappling und Kindertraining
            findest du im Stundenplan.
          </p>
          <a href="/stundenplan" class="mt-3 inline-block text-sm font-semibold text-primary transition-smooth hover:opacity-80">
            Zum Stundenplan →
          </a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

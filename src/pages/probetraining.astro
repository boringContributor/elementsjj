---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactButtons from '../components/ContactButtons.astro';
import { SITE, LOCATIONS } from '../data/site';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Probetraining', href: '/probetraining' },
];

const accentText = { blue: 'text-course-blue', red: 'text-primary', gold: 'text-primary' } as const;

const checklist = [
  'Sportkleidung (kurze Hose, T-Shirt)',
  'Wasserflasche & Handtuch',
  'Gute Laune & Offenheit',
  'Gi (BJJ): leihen wir dir gerne',
];
---

<BaseLayout
  title="Kostenloses Probetraining — Elements Jiu Jitsu Regensburg"
  description="Buche dein kostenloses Probetraining bei EJJ Regensburg. BJJ, MMA, Thaiboxen — Anfänger willkommen."
  breadcrumbs={breadcrumbs}
  hideStickyCta
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-display text-sm font-semibold tracking-[0.2em] text-primary uppercase">
        Gratis &amp; unverbindlich
      </p>
      <h1 class="font-display mt-2 text-3xl font-bold uppercase sm:text-4xl">
        Dein <span class="text-primary">Probetraining</span>
      </h1>
      <p class="mt-4 text-muted-foreground">
        Buch dein kostenloses Probetraining direkt online — wir freuen uns auf dich!
      </p>
    </div>

    <div class="mt-12 grid items-start gap-8 lg:grid-cols-[minmax(0,1fr)_340px]">
      <div class="overflow-hidden rounded-lg border border-border bg-card">
        <div
          id="matool-consent-placeholder"
          class="flex min-h-[420px] flex-col items-center justify-center gap-4 px-6 py-12 text-center"
          data-matool-src={SITE.matoolFormUrl}
        >
          <div class="max-w-xl space-y-3">
            <p class="font-display text-xl font-semibold tracking-wide uppercase">Externes Buchungsformular laden</p>
            <p class="text-sm leading-relaxed text-muted-foreground">
              Für die Anmeldung zum Probetraining nutzen wir das Buchungsformular von MATOOL. Beim
              Laden können personenbezogene Daten wie deine IP-Adresse an MATOOL übertragen und
              dort Cookies oder ähnliche Technologien eingesetzt werden.
            </p>
          </div>
          <button
            id="matool-consent-button"
            type="button"
            class="gradient-neon rounded-md px-5 py-2.5 text-sm font-semibold text-primary-foreground transition-smooth hover:brightness-110"
          >
            MATOOL-Formular laden
          </button>
          <a href="/datenschutz" class="text-sm font-medium text-primary underline-offset-4 hover:underline">
            Hinweise zum Datenschutz
          </a>
        </div>
        <p class="border-t border-border px-4 py-2 text-right text-xs text-muted-foreground">
          made by
          <a href="https://www.matool.de" target="_blank" rel="noopener noreferrer" class="font-semibold hover:text-primary">MATOOL</a>
        </p>
      </div>

      <aside class="space-y-4">
        <div class="rounded-lg border border-border bg-card p-6">
          <h2 class="font-display text-base font-bold tracking-wider uppercase">Standorte</h2>
          <ul class="mt-4 space-y-4">
            {LOCATIONS.map((loc) => (
              <li>
                <p class:list={['font-display text-sm font-semibold uppercase', accentText[loc.accent]]}>{loc.name}</p>
                <p class="text-sm text-muted-foreground">{loc.address}</p>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-lg border border-border bg-card p-6">
          <h2 class="font-display text-base font-bold tracking-wider uppercase">Direkt kontaktieren</h2>
          <ContactButtons class="mt-4" />
        </div>

        <div class="rounded-lg border border-border bg-card p-6">
          <h2 class="font-display text-base font-bold tracking-wider uppercase">Hinweis für Minderjährige</h2>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Beim Probetraining muss ein Erziehungsberechtigter vor Ort einen Haftungsausschluss
            unterschreiben.
          </p>
        </div>

        <div class="rounded-lg border border-border bg-card p-6">
          <h2 class="font-display text-base font-bold tracking-wider uppercase">Was du mitbringen solltest</h2>
          <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
            {checklist.map((item) => (
              <li class="flex gap-2">
                <span class="text-primary" aria-hidden="true">•</span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-lg border border-border bg-card p-6">
          <h2 class="font-display text-base font-bold tracking-wider uppercase">Disziplinen &amp; Zeiten finden</h2>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Alle Termine und Standorte für BJJ, MMA, Thaiboxen, Grappling und Kindertraining
            findest du im Stundenplan.
          </p>
          <a href="/stundenplan" class="mt-3 inline-block text-sm font-semibold text-primary transition-smooth hover:opacity-80">
            Zum Stundenplan →
          </a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>


<script>
  const storageKey = 'elementsjj-cookie-consent';
  const placeholder = document.getElementById('matool-consent-placeholder');
  const matoolButton = document.getElementById('matool-consent-button');

  const readConsent = () => {
    try {
      const rawConsent = window.localStorage.getItem(storageKey);
      if (!rawConsent) return null;
      if (rawConsent === 'accepted') return { essential: true, external: false };
      return JSON.parse(rawConsent);
    } catch {
      return null;
    }
  };

  const saveExternalConsent = () => {
    const consent = { essential: true, external: true, updatedAt: new Date().toISOString() };
    try {
      window.localStorage.setItem(storageKey, JSON.stringify(consent));
    } catch {
      // Wenn localStorage nicht verfügbar ist, laden wir das Formular nur für den aktuellen Seitenaufruf.
    }
    window.dispatchEvent(new CustomEvent('elementsjj:consent-updated', { detail: consent }));
  };

  const loadMatoolForm = () => {
    if (!placeholder || placeholder.dataset.loaded === 'true') return;
    const source = placeholder.dataset.matoolSrc;
    if (!source) return;

    const iframe = document.createElement('iframe');
    iframe.src = source;
    iframe.title = 'Probetraining-Anmeldung (Buchungsformular von MATOOL)';
    iframe.className = 'block h-[620px] w-full sm:h-[max(820px,calc(100dvh-12rem))]';
    iframe.sandbox.add('allow-scripts', 'allow-same-origin', 'allow-forms', 'allow-popups');
    iframe.loading = 'lazy';

    placeholder.replaceWith(iframe);
  };

  if (readConsent()?.external) {
    loadMatoolForm();
  }

  matoolButton?.addEventListener('click', () => {
    saveExternalConsent();
    loadMatoolForm();
  });

  window.addEventListener('elementsjj:consent-updated', (event) => {
    if (event instanceof CustomEvent && event.detail?.external) {
      loadMatoolForm();
    }
  });
</script>

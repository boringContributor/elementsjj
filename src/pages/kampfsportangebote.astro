---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import OfferCard from '../components/OfferCard.astro';
import { OFFERS } from '../data/offers';

const offerCatalogLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Sportangebote in Regensburg und Kelheim',
  itemListElement: OFFERS.map((offer, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: offer.name,
    description: offer.desc,
    url: new URL(offer.href, Astro.site).href,
  })),
};

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Sportangebot', href: '/kampfsportangebote' },
];
---

<BaseLayout
  title="Sportangebot — Elements Jiu Jitsu Regensburg"
  description="BJJ, MMA, Thaiboxen/Kickboxen, Grappling, Frauenkurse, Kindertraining und Open Mat bei EJJ in Regensburg und Kelheim. Kostenloses Probetraining für Anfänger."
  breadcrumbs={breadcrumbs}
  jsonLd={[offerCatalogLd]}
  keywords={['Kampfsport Regensburg', 'BJJ Regensburg', 'MMA Regensburg', 'Thaiboxen Regensburg', 'Grappling Kelheim', 'Kindertraining Regensburg']}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <SectionHeading kicker="Was wir trainieren" as="h1">
      Unser Sportangebot
    </SectionHeading>
    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {OFFERS.map((offer, index) => (
        <OfferCard offer={offer} loading={index < 4 ? 'eager' : 'lazy'} />
      ))}
    </div>
    <div class="mt-12 text-center">
      <a
        href="/probetraining"
        class="gradient-neon shadow-neon inline-block rounded-md px-8 py-3 font-semibold text-primary-foreground transition-smooth hover:opacity-90"
      >
        Kostenloses Schnuppertraining buchen
      </a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactButtons from '../components/ContactButtons.astro';
import { SITE } from '../data/site';
import { PROBETRAINING_FAQS, faqJsonLd } from '../data/faqs';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'FAQ', href: '/faq' },
];

const faqs = PROBETRAINING_FAQS;

const faqSchema = faqJsonLd(faqs);
---

<BaseLayout
  title="FAQ zum Probetraining — Elements Jiu Jitsu Regensburg"
  description="Antworten auf häufige Fragen vor deinem Probetraining bei Elements Jiu Jitsu: Ausrüstung, Anfänger, Kindertraining, Kosten und Anmeldung."
  breadcrumbs={breadcrumbs}
  jsonLd={[faqSchema]}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <SectionHeading kicker="Vor dem ersten Training" as="h1">
      Häufige Fragen zum Probetraining
      <Fragment slot="sub">
        <p>
          Du willst starten, bist dir aber noch unsicher? Hier findest du die wichtigsten Antworten,
          bevor du dein kostenloses Probetraining bei uns ausmachst.
        </p>
      </Fragment>
    </SectionHeading>

    <div class="mt-12 space-y-4">
      {faqs.map((faq) => (
        <details class="group rounded-lg border border-border bg-card p-6 transition-smooth open:border-primary/60 open:shadow-neon-soft">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-4 font-display text-lg font-semibold uppercase tracking-wide text-foreground [&::-webkit-details-marker]:hidden">
            <span>{faq.question}</span>
            <span class="mt-1 text-primary transition-transform group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <p class="mt-4 leading-relaxed text-muted-foreground">{faq.answer}</p>
          {faq.answer.includes('WhatsApp') && (
            <ContactButtons class="mt-5" />
          )}
        </details>
      ))}
    </div>

    <div class="mt-14 rounded-lg border border-border bg-card p-8 text-center">
      <h2 class="font-display text-2xl font-bold uppercase">
        Noch eine Frage offen?
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-muted-foreground">
        Schreib uns kurz oder sichere dir direkt deinen Platz fürs kostenlose und unverbindliche Probetraining.
      </p>
      <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
        <a
          href="/probetraining"
          class="gradient-neon shadow-neon inline-flex items-center justify-center rounded-md px-8 py-3 font-semibold text-primary-foreground transition-smooth hover:opacity-90"
        >
          Probetraining buchen
        </a>
        <a
          href={SITE.whatsapp.base}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-md bg-[#25d366] px-8 py-3 font-semibold text-black transition-smooth hover:brightness-110"
        >
          Per WhatsApp fragen
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

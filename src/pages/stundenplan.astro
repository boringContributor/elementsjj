---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ScheduleTable from '../components/ScheduleTable.astro';
import { DAY_ORDER, DAYS_DE, GYMS, SESSIONS } from '../data/schedule';

const sportFilters = [
  { label: 'Alle', value: 'all' },
  { label: 'BJJ', value: 'bjj' },
  { label: 'MMA', value: 'mma' },
  { label: 'Grappling', value: 'nogi' },
  { label: 'Kickboxen', value: 'kickboxen' },
  { label: 'Kindertraining', value: 'kindertraining' },
  { label: 'Frauen', value: 'frauen' },
];

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Stundenplan', href: '/stundenplan' },
];

const jumpLinks = GYMS.map((gym) => ({ href: `#${gym.id}`, label: gym.label, id: gym.id }));
const jumpLinkClasses: Record<string, string> = {
  blue: 'border-course-blue/60 text-course-blue hover:border-course-blue hover:bg-course-blue hover:text-background',
  red: 'border-primary/60 text-primary hover:border-primary hover:bg-primary hover:text-primary-foreground',
  kelheim: 'border-gold/60 text-gold hover:border-gold hover:bg-gold hover:text-background',
};

const compactScheduleDays = DAY_ORDER.map((day) => ({
  day,
  label: DAYS_DE[day]!,
  sessions: SESSIONS.filter((session) => session.day === day).sort((a, b) => {
    const byStart = a.start.localeCompare(b.start);
    return byStart !== 0 ? byStart : a.track.localeCompare(b.track);
  }),
})).filter((day) => day.sessions.length > 0);

const trackBadgeClasses: Record<string, string> = {
  Blue: 'border-course-blue/50 bg-course-blue/10 text-course-blue',
  Red: 'border-primary/50 bg-primary/10 text-primary',
  Kelheim: 'border-gold/50 bg-gold/10 text-gold',
};
---

<BaseLayout
  title="Stundenplan — Elements Jiu Jitsu Regensburg & Kelheim"
  description="Trainingszeiten für BJJ, NoGi, MMA, Thaiboxen, Grappling und Kindertraining in Regensburg sowie Brazilian Jiu Jitsu und NoGi Grappling in Kelheim."
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <SectionHeading kicker="Trainingszeiten" as="h1">
      Stundenplan
      <Fragment slot="sub">
        <p>
          Sieben Tage die Woche auf der Matte. Wähle deinen Standort und such dir deine Klasse —
          Probetraining ist immer kostenlos.
        </p>
      </Fragment>
    </SectionHeading>

    <nav class="mt-8 flex justify-center gap-3" aria-label="Standorte im Stundenplan">
      {jumpLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-md border px-4 py-2 text-sm font-semibold transition-smooth',
            jumpLinkClasses[link.id] ?? 'border-border hover:border-primary hover:text-primary',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="mt-8 rounded-lg border border-border bg-card p-4" aria-label="Stundenplan nach Sportart filtern">
      <p class="text-center font-display text-sm font-semibold tracking-[0.2em] text-muted-foreground uppercase">
        Nach Sportart filtern
      </p>
      <div class="mt-4 flex flex-wrap justify-center gap-3" data-schedule-filters>
        {sportFilters.map((filter) => (
          <button
            type="button"
            class="rounded-md border border-border px-4 py-2 text-sm font-semibold transition-smooth hover:border-primary hover:text-primary aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground"
            data-schedule-filter={filter.value}
            aria-pressed={filter.value === 'all' ? 'true' : 'false'}
          >
            {filter.label}
          </button>
        ))}
      </div>
    </div>

    <div class="mt-12 space-y-14">
      {GYMS.map((gym) => (
        <ScheduleTable gym={gym} />
      ))}
    </div>

    <div class="mt-14 rounded-lg border border-border bg-card p-8 text-center">
      <h2 class="font-display text-2xl font-bold uppercase">
        Erstes Training? <span class="text-primary">Gratis.</span>
      </h2>
      <p class="mx-auto mt-3 max-w-md text-muted-foreground">
        Buche dein kostenloses Probetraining — bring bequeme Kleidung sowie Hausschuhe oder Badeschlappen für die Wege abseits der Matte (z. B. Umkleide) mit.
      </p>
      <a
        href="/probetraining"
        class="gradient-neon shadow-neon mt-6 inline-block rounded-md px-8 py-3 font-semibold text-primary-foreground transition-smooth hover:opacity-90"
      >
        Probetraining buchen
      </a>
    </div>

    <section class="mt-14 rounded-xl border border-border bg-card p-4 shadow-lg sm:p-6" aria-labelledby="kompaktplan-heading">
      <div class="text-center">
        <p class="font-display text-sm font-semibold tracking-[0.2em] text-muted-foreground uppercase">
          Wochenübersicht
        </p>
        <h2 id="kompaktplan-heading" class="font-display mt-2 text-2xl font-bold uppercase">
          Alle Einheiten auf einen Blick
        </h2>
        <p class="mx-auto mt-3 max-w-2xl text-sm text-muted-foreground">
          Kompakter Stundenplan im Schulplan-Stil: alle Kurse nach Wochentagen sortiert, inklusive Standort.
          In Kelheim finden ausschließlich Brazilian Jiu Jitsu und NoGi Grappling statt.
        </p>
      </div>

      <div class="mt-6 overflow-x-auto rounded-lg border border-border">
        <div class="grid min-w-[980px] grid-cols-7 divide-x divide-border bg-background/60">
          {compactScheduleDays.map((day) => (
            <article class="flex min-h-full flex-col">
              <h3 class="border-b border-border bg-secondary/70 px-3 py-3 text-center font-display text-sm font-bold tracking-wider uppercase">
                {day.label}
              </h3>
              <div class="flex flex-1 flex-col gap-2 p-2">
                {day.sessions.map((session) => (
                  <div class="rounded-md border border-border bg-card/80 p-2 text-xs">
                    <div class="flex items-center justify-between gap-2">
                      <time class="font-mono font-semibold text-foreground">
                        {session.start}–{session.end}
                      </time>
                      <span class:list={[
                        'shrink-0 rounded border px-1.5 py-0.5 text-[10px] font-semibold uppercase',
                        trackBadgeClasses[session.track],
                      ]}>
                        {session.track}
                      </span>
                    </div>
                    <p class="mt-1 font-semibold leading-snug">{session.discipline}</p>
                    {session.level && (
                      <p class="mt-0.5 text-[11px] leading-snug text-muted-foreground">{session.level}</p>
                    )}
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </section>
  <script>
    const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-schedule-filter]'));
    const gyms = Array.from(document.querySelectorAll<HTMLElement>('[data-schedule-gym]'));

    function applyScheduleFilter(activeFilter: string) {
      filterButtons.forEach((button) => {
        button.setAttribute('aria-pressed', String(button.dataset.scheduleFilter === activeFilter));
      });

      gyms.forEach((gym) => {
        const days = Array.from(gym.querySelectorAll<HTMLElement>('[data-schedule-day]'));
        let hasVisibleSlot = false;

        days.forEach((day) => {
          const slots = Array.from(day.querySelectorAll<HTMLElement>('[data-schedule-slot]'));
          let hasVisibleDaySlot = false;

          slots.forEach((slot) => {
            const categories = (slot.dataset.sportCategories ?? '').split(' ').filter(Boolean);
            const isVisible = activeFilter === 'all' || categories.includes(activeFilter);
            slot.classList.toggle('hidden', !isVisible);
            hasVisibleDaySlot ||= isVisible;
          });

          day.classList.toggle('hidden', !hasVisibleDaySlot);
          hasVisibleSlot ||= hasVisibleDaySlot;
        });

        gym.querySelector<HTMLElement>('[data-schedule-empty]')?.classList.toggle('hidden', hasVisibleSlot);
      });
    }

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => applyScheduleFilter(button.dataset.scheduleFilter ?? 'all'));
    });
  </script>
</BaseLayout>

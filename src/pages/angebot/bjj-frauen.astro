---
import OfferShell from '../../components/OfferShell.astro';
import BenefitCard from '../../components/BenefitCard.astro';
import { OFFERS } from '../../data/offers';

const image = OFFERS.find((offer) => offer.slug === 'bjj-frauen')!.image;
---

<OfferShell
  title="BJJ für Frauen in Regensburg & Kelheim — Elements Jiu Jitsu"
  description="Brazilian Jiu-Jitsu für Frauen in Regensburg & Kelheim: realistische Selbstverteidigung, Fitness, mentale Stärke und eine starke Community. Kostenloses Probetraining sichern."
  kicker="Kampfsportangebot"
  heading="BJJ für Frauen in"
  headingAccent="Regensburg & Kelheim"
  subtitle="Empowerment auf der Matte — Erlerne hocheffektive Selbstverteidigung, stärke dein Selbstbewusstsein und werde Teil einer großartigen Community."
  ogImage={image}
  slug="bjj-frauen"
  equipment={[
    ['Kleidung:', 'Eine normale, bequeme Sporthose oder Leggings (ohne Reißverschlüsse) und ein sauberes T-Shirt. Trainiert wird barfuß.'],
    ['Wichtig:', 'Ein Handtuch, ausreichend zu trinken und eine offene Einstellung.'],
  ]}
  ctaLabel="Jetzt kostenloses Frauen-BJJ Probetraining vereinbaren"
>
  <section>
    <h2 class="font-display text-2xl font-bold uppercase">Warum Brazilian Jiu-Jitsu für Frauen?</h2>
    <p class="mt-4 leading-relaxed text-muted-foreground">
      Brazilian Jiu-Jitsu (BJJ) ist die wohl effektivste Kampfsportart für Frauen, da sie von Grund
      auf darauf ausgelegt ist, größere und schwerere Angreifer durch Hebelwirkung, Griffe und
      clevere Positionierung am Boden zu kontrollieren. Beim BJJ lernst du nicht, Kraft gegen Kraft
      zu setzen – du lernst, Biomechanik und Technik für dich zu nutzen. Unser Frauen-BJJ-Programm
      bei Elements bietet dir eine sichere, respektvolle und motivierende Umgebung, um über dich
      hinauszuwachsen, fit zu werden und reale Selbstverteidigung zu lernen.
    </p>
  </section>

  <section>
    <h2 class="font-display text-2xl font-bold uppercase">Deine Vorteile bei Elements</h2>
    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      <BenefitCard title="Realistische Selbstverteidigung">
        Lerne, wie du dich in engen, körperlichen Situationen — besonders in der Bodenlage —
        effektiv und instinktiv behauptest und die Kontrolle übernimmst.
      </BenefitCard>
      <BenefitCard title="Ganzkörper-Fitness & Core-Stärke">
        BJJ fordert Muskeln, von denen du gar nicht wusstest, dass du sie hast. Verbessere deine
        Kondition, Beweglichkeit und funktionelle Kraft im eigenen Tempo.
      </BenefitCard>
      <BenefitCard title="Mentale Stärke & Empowerment">
        Das Überwinden von Herausforderungen auf der Matte baut ein unerschütterliches
        Selbstbewusstsein auf, das dich auch im Alltag und Beruf mental stärkt.
      </BenefitCard>
      <BenefitCard title="Starke Gemeinschaft">
        Bei Elements trainierst du mit gleichgesinnten Frauen und Partnern, die sich gegenseitig
        unterstützen. Keine Ellbogenmentalität — sondern gemeinsamer Fortschritt und viel Spaß.
      </BenefitCard>
    </div>
  </section>

  <section class="rounded-lg border border-border bg-card p-6">
    <h2 class="font-display text-2xl font-bold uppercase">Jedes Fitnesslevel ist willkommen</h2>
    <p class="mt-4 leading-relaxed text-muted-foreground">
      Egal ob du absolute Anfängerin bist, noch nie Kampfsport gemacht hast oder deine Fitness aufs
      nächste Level bringen willst: Wir holen dich genau da ab, wo du stehst. Unsere erfahrenen
      Trainer achten sensibel darauf, dass jede Technik sauber und verletzungsfrei erlernt wird.
      BJJ ist ein hervorragender Stresskiller — nach dem Training verlässt du die Matte mit freiem
      Kopf und einem stolzen Gefühl.
    </p>
  </section>
</OfferShell>

---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaSection from '../components/CtaSection.astro';
import { TRAINERS } from '../data/trainers';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Team', href: '/team' },
];
---

<BaseLayout
  title="Team — Elements Jiu Jitsu Regensburg"
  description="Unser Trainer-Team bei Elements Jiu Jitsu Regensburg."
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <SectionHeading kicker="Coaches & Athleten" as="h1">
      Unser Trainer-Team
      <Fragment slot="sub">
        <p>
          23 Coaches, eine Mission: dich besser machen. Vom Schwarzgurt-Headcoach bis zum jungen
          Athleten — bei EJJ trainieren echte Mattenleute.
        </p>
      </Fragment>
    </SectionHeading>

    <ul class="mt-12 grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-5">
      {TRAINERS.map((trainer, index) => (
        <li class="overflow-hidden rounded-lg border border-border bg-card">
          <Image
            src={trainer.image}
            alt={`${trainer.name} — Trainer bei Elements Jiu Jitsu Regensburg`}
            widths={[240, 480]}
            sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 20vw"
            class="aspect-[4/5] w-full object-cover object-top"
            loading={index < 5 ? 'eager' : 'lazy'}
          />
          <p class="px-3 py-3 text-center text-sm font-semibold">{trainer.name}</p>
        </li>
      ))}
    </ul>
  </section>

  <CtaSection />
</BaseLayout>

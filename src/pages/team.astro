---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaSection from '../components/CtaSection.astro';
import TrainerSection from '../components/TrainerSection.astro';
import { TRAINER_TAGS } from '../data/trainers';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Team', href: '/team' },
];
---

<BaseLayout
  title="Team — Elements Jiu Jitsu Regensburg"
  description="Unser Trainer-Team bei Elements Jiu Jitsu Regensburg."
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <SectionHeading kicker="Coaches & Athleten" as="h1">
      Unser Trainer-Team
      <Fragment slot="sub">
        <p>
          Ein Team vieler Coaches, eine Mission: dich besser machen. Vom Schwarzgurt-Headcoach bis zum jungen Athleten — bei EJJ trainieren echte Matpeople.
        </p>
      </Fragment>
    </SectionHeading>

    <div class="mt-12">
      <TrainerSection tags={[...TRAINER_TAGS]} title="Alle Trainer" />
    </div>
  </section>

  <CtaSection />
</BaseLayout>
